{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ES2023"]
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules"]
}
