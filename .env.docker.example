# Plantilla de variables para el despliegue con Docker en el droplet.
# Copiar a ".env" en la raíz del repo EN EL DROPLET (no committear el real —
# ya está en .gitignore) y llenar con los valores de producción.
#
# docker-compose.yml lee este archivo dos veces:
#  - como env_file del backend (todas las variables abajo)
#  - para sustituir ${DOMAIN} dentro del propio docker-compose.yml

# Dominio público del droplet, con DNS (registro A) ya apuntando a esta IP.
# Caddy usa este valor para emitir el certificado HTTPS automáticamente.
DOMAIN=revenue.gehsuites.com

# MongoDB (mismo cluster Atlas que usa hoy la app Next.js — no cambia)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/calculo-promociones

# Secreto para cifrar la cookie de sesión (AES-256-GCM) — generar uno nuevo
# y distinto al de dev, mínimo 32 caracteres aleatorios.
SESSION_SECRET=

# Google OAuth (One Tap login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://revenue.gehsuites.com/api/google-business/callback

# Bitrix24 (usado por Financiera y Monitoreo)
BITRIX_BASE_URL=https://gehsuites.bitrix24.com/rest
BITRIX_WEBHOOK_USER_ID=14
APIKEY_BITRIX=
BITRIX_DEPARTMENT_ID=18

# PMS (usado por Financiera)
PMS_PORT=59000
PMS_EMAIL=
PMS_PASSWORD=
